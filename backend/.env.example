# ─── Turso Database ──────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Admin Auth ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate bcrypt hash: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here
JWT_SECRET=your-super-secret-jwt-key-256-bits-random

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=wildfirewatch
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─── App Settings ─────────────────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=500
TEMP_DIR=/tmp
FRONTEND_URL=https://your-app.vercel.app
