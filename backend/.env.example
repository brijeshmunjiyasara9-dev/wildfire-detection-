# ─── Turso (LibSQL) Database ──────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Admin Credentials ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-256-bit-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=wildfirewatch
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── App Settings ─────────────────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=500
TEMP_DIR=/tmp
FRONTEND_URL=https://your-app.vercel.app
